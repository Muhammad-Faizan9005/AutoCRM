# Application Settings
APP_NAME=AutoCRM
DEBUG=True

# Database Settings (single switch)
# Use one PostgreSQL connection string.
# Example Supabase pooler:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# Example Neon:
# DATABASE_URL=postgresql://<user>:<password>@<endpoint>.neon.tech/<database>?sslmode=require
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=3600
DB_MAX_CONCURRENT_OPERATIONS=5

# LLM Settings (supports any LLM provider)
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4
LLM_BASE_URL=

# JWT Settings
JWT_SECRET_KEY=your-super-secret-key-change-this-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password reset
RESET_TOKEN_TTL_MINUTES=30

# Security hardening
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=120
MAX_REQUEST_SIZE_BYTES=1048576
SECURITY_HEADERS_ENABLED=True

# Shared meeting recordings storage
# Point backend and AI service at the same folder. Use a network/shared path
# when moving between devices, for example \\SERVER\AutoCRMRecordings.
AUTOCRM_RECORDINGS_DIR=storage/recordings

# AI service callbacks
AI_SERVICE_BASE_URL=http://localhost:8001
AI_TRANSCRIPTION_NOTIFY_ENABLED=true
AI_SERVICE_NOTIFY_TIMEOUT_SECONDS=10
AI_SERVICE_WEBHOOK_TOKEN=change-me-shared-token

# Backward-compatible aliases (optional)
# SECRET_KEY=your-super-secret-key-change-this-min-32-chars
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
