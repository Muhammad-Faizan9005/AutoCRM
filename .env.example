# Application Settings
APP_NAME=AutoCRM
DEBUG=True

# Supabase Settings
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-anon-key
# Optional fallback keys (used if SUPABASE_KEY is not provided)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# Recommended DATABASE_URL format (Supabase Transaction Pooler)
# postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=your-database-url

# LLM Settings (supports any LLM provider)
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4
LLM_BASE_URL=

# JWT Settings
JWT_SECRET_KEY=your-super-secret-key-change-this-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Security hardening
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=120
MAX_REQUEST_SIZE_BYTES=1048576
SECURITY_HEADERS_ENABLED=True

# Backward-compatible aliases (optional)
# SECRET_KEY=your-super-secret-key-change-this-min-32-chars
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
