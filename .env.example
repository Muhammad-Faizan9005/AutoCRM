# Application Settings
APP_NAME=AutoCRM
DEBUG=True

# Database Settings (single switch)
# Use one PostgreSQL connection string.
# Example Supabase pooler:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# Example Neon:
# DATABASE_URL=postgresql://<user>:<password>@<endpoint>.neon.tech/<database>?sslmode=require
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# LLM Settings (supports any LLM provider)
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4
LLM_BASE_URL=

# JWT Settings
JWT_SECRET_KEY=your-super-secret-key-change-this-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Security hardening
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=120
MAX_REQUEST_SIZE_BYTES=1048576
SECURITY_HEADERS_ENABLED=True

# Backward-compatible aliases (optional)
# SECRET_KEY=your-super-secret-key-change-this-min-32-chars
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
